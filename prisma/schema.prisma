generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  MARKETPLACE_ADMIN
  SELLER
}

model User {
  id             String    @id @default(uuid()) @db.Uuid
  role           UserRole
  marketplaceId  String?   @map("marketplace_id") @db.Uuid
  email          String    @unique
  passwordHash   String    @map("password_hash")
  createdAt      DateTime  @default(now()) @map("created_at")

  products Product[]

  @@index([marketplaceId])
  @@map("users")
}

model Product {
  id                 String    @id @default(uuid()) @db.Uuid
  sellerId           String    @map("seller_id") @db.Uuid
  title              String
  description        String?
  brand              String?
  category           String?
  countryOfOrigin    String?   @map("country_of_origin")
  hsCode             String?   @map("hs_code")
  midCode            String?   @map("mid_code")
  aiAttributes       Json?     @map("ai_attributes")
  aiConfidenceScore  Int?      @map("ai_confidence_score")
  requiresReview     Boolean   @default(false) @map("requires_review")
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  seller   User      @relation(fields: [sellerId], references: [id])
  variants Variant[]

  @@index([sellerId])
  @@map("products")
}

model Variant {
  id         String  @id @default(uuid()) @db.Uuid
  productId  String  @map("product_id") @db.Uuid
  sku        String  @unique
  price      Decimal @db.Decimal(10, 2)
  weightKg   Decimal? @map("weight_kg") @db.Decimal(10, 3)
  lengthCm   Decimal? @map("length_cm") @db.Decimal(10, 2)
  widthCm    Decimal? @map("width_cm") @db.Decimal(10, 2)
  heightCm   Decimal? @map("height_cm") @db.Decimal(10, 2)
  attributes Json?

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("variants")
}

model Workspace {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @default("My Workspace")
  ownerUserId String?  @map("owner_user_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  apiKeys ApiKey[]

  @@index([ownerUserId])
  @@map("workspaces")
}

model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  prefix      String    @unique
  keyHash     String    @map("key_hash")
  name        String
  lastUsedAt  DateTime? @map("last_used_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([prefix])
  @@map("api_keys")
}

model RequestLog {
  id          String   @id @default(uuid()) @db.Uuid
  requestId   String   @map("request_id")
  method      String
  path        String
  statusCode  Int      @map("status_code")
  responseMs  Int      @map("response_ms")
  keyPrefix   String?  @map("key_prefix")
  workspaceId String?  @map("workspace_id") @db.Uuid
  errorMsg    String?  @map("error_msg")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([createdAt])
  @@index([keyPrefix])
  @@map("request_logs")
}

model UsageCounter {
  id          String @id @default(uuid()) @db.Uuid
  workspaceId String @map("workspace_id") @db.Uuid
  month       String // "2026-04" format for easy querying
  endpoint    String // e.g. "classify", "products.create", "products.list"
  count       Int    @default(0)

  @@unique([workspaceId, month, endpoint])
  @@index([workspaceId, month])
  @@map("usage_counters")
}

model ClassificationRecord {
  id                  String   @id @default(uuid()) @db.Uuid
  workspaceId         String?  @map("workspace_id") @db.Uuid
  productUrl          String?  @map("product_url")
  sourceTitle         String?  @map("source_title")
  imageStoragePath    String?  @map("image_storage_path")
  hsCode              String   @map("hs_code")
  midCode             String?  @map("mid_code")
  confidenceScore     Int      @map("confidence_score")
  requiresReview      Boolean  @default(false) @map("requires_review")
  countryOfOrigin     String?  @map("country_of_origin")
  materials           String?
  restrictedGoodsFlag Boolean  @default(false) @map("restricted_goods_flag")
  customsDescription  String?  @map("customs_description")
  aiAttributes        Json?    @map("ai_attributes")
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([workspaceId, createdAt])
  @@map("classification_records")
}
