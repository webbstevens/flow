generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  MARKETPLACE_ADMIN
  SELLER
}

model User {
  id             String    @id @default(uuid()) @db.Uuid
  role           UserRole
  marketplaceId  String?   @map("marketplace_id") @db.Uuid
  email          String    @unique
  passwordHash   String    @map("password_hash")
  createdAt      DateTime  @default(now()) @map("created_at")

  products Product[]

  @@index([marketplaceId])
  @@map("users")
}

model Product {
  id                 String    @id @default(uuid()) @db.Uuid
  sellerId           String    @map("seller_id") @db.Uuid
  title              String
  description        String?
  brand              String?
  category           String?
  countryOfOrigin    String?   @map("country_of_origin")
  hsCode             String?   @map("hs_code")
  midCode            String?   @map("mid_code")
  aiAttributes       Json?     @map("ai_attributes")
  aiConfidenceScore  Int?      @map("ai_confidence_score")
  requiresReview     Boolean   @default(false) @map("requires_review")
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  seller   User      @relation(fields: [sellerId], references: [id])
  variants Variant[]

  @@index([sellerId])
  @@map("products")
}

model Variant {
  id         String  @id @default(uuid()) @db.Uuid
  productId  String  @map("product_id") @db.Uuid
  sku        String  @unique
  price      Decimal @db.Decimal(10, 2)
  weightKg   Decimal? @map("weight_kg") @db.Decimal(10, 3)
  lengthCm   Decimal? @map("length_cm") @db.Decimal(10, 2)
  widthCm    Decimal? @map("width_cm") @db.Decimal(10, 2)
  heightCm   Decimal? @map("height_cm") @db.Decimal(10, 2)
  attributes Json?

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("variants")
}

model Workspace {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @default("My Workspace")
  ownerUserId String?  @map("owner_user_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  apiKeys ApiKey[]

  @@index([ownerUserId])
  @@map("workspaces")
}

model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  prefix      String    @unique
  keyHash     String    @map("key_hash")
  name        String
  lastUsedAt  DateTime? @map("last_used_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([prefix])
  @@map("api_keys")
}

model RequestLog {
  id          String   @id @default(uuid()) @db.Uuid
  requestId   String   @map("request_id")
  method      String
  path        String
  statusCode  Int      @map("status_code")
  responseMs  Int      @map("response_ms")
  keyPrefix   String?  @map("key_prefix")
  workspaceId String?  @map("workspace_id") @db.Uuid
  errorMsg    String?  @map("error_msg")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([workspaceId])
  @@index([createdAt])
  @@index([keyPrefix])
  @@map("request_logs")
}

model UsageCounter {
  id          String @id @default(uuid()) @db.Uuid
  workspaceId String @map("workspace_id") @db.Uuid
  month       String // "2026-04" format for easy querying
  endpoint    String // e.g. "classify", "products.create", "products.list"
  count       Int    @default(0)

  @@unique([workspaceId, month, endpoint])
  @@index([workspaceId, month])
  @@map("usage_counters")
}

model ClassificationRecord {
  id                  String   @id @default(uuid()) @db.Uuid
  workspaceId         String?  @map("workspace_id") @db.Uuid
  productUrl          String?  @map("product_url")
  sourceTitle         String?  @map("source_title")
  imageStoragePath    String?  @map("image_storage_path")
  hsCode              String   @map("hs_code")
  midCode             String?  @map("mid_code")
  confidenceScore     Int      @map("confidence_score")
  requiresReview      Boolean  @default(false) @map("requires_review")
  countryOfOrigin     String?  @map("country_of_origin")
  destinationCountry  String?  @map("destination_country")
  materials           String?
  restrictedGoodsFlag Boolean  @default(false) @map("restricted_goods_flag")
  customsDescription  String?  @map("customs_description")
  aiAttributes        Json?    @map("ai_attributes")
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([workspaceId, createdAt])
  @@map("classification_records")
}

/// Cached GRI-step analysis + section/chapter note review per (HS10, attribute hash).
/// Keyed on full HS10 because rationale is line-specific; attributes hash lets two
/// records classifying the same product share one row. See src/lib/rationale.ts.
model ClassificationRationale {
  id             String    @id @default(uuid()) @db.Uuid
  hsCode         String    @map("hs_code") // full 10-digit HTS line
  attributesHash String    @map("attributes_hash") // sha256 of normalized (title|materials|category)
  griSteps       Json      @default("[]") @map("gri_steps")
  notesReviewed  Json      @default("[]") @map("notes_reviewed")
  status         String // 'flow_validating' | 'verified' | 'manual_override'
  source         String // 'llm' | 'wco_explanatory_notes' | 'manual'
  confidence     Int?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  verifiedAt     DateTime? @map("verified_at")

  @@unique([hsCode, attributesHash])
  @@index([hsCode])
  @@map("classification_rationales")
}

/// Registry of US federal agencies whose rules can touch imports (CBP PGAs +
/// adjacent regulators — FDA, APHIS, FWS, EPA, CPSC, TTB, DDTC, OFAC, etc.).
/// Used as a reference the classify/requirements prompt constrains against so
/// Claude can't invent certificate codes. See scripts/seed-regulation-catalog.ts.
model RegulationAgency {
  id               String    @id @default(uuid()) @db.Uuid
  code             String    @unique // 'FDA', 'APHIS', 'FWS', 'DOT_NHTSA', ...
  name             String // 'Food and Drug Administration'
  parentDepartment String    @map("parent_department") // 'HHS', 'USDA', 'DOI', 'DOT', 'Treasury'
  scope            String // one-line description of what they regulate at the border
  pgaCode          String?   @map("pga_code") // CBP ACE PGA message set code, nullable
  url              String? // official agency page
  status           String // 'flow_validating' | 'verified' | 'manual_override'
  source           String // 'llm' | 'cbp_pga' | 'manual'
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  verifiedAt       DateTime? @map("verified_at")

  certificates CertificateCatalog[]

  @@map("regulation_agencies")
}

/// Canonical list of documents / certificates / filings that can be required
/// at US import. Each row belongs to exactly one RegulationAgency. The
/// classify/requirements prompt is fed this catalog; LLM output must reference
/// `code` values from this table rather than inventing new strings.
model CertificateCatalog {
  id                    String    @id @default(uuid()) @db.Uuid
  code                  String    @unique // 'FDA_2877', 'FWS_3_177', 'EPA_3520_1', 'CPSC_GCC'
  agencyCode            String    @map("agency_code") // FK to regulation_agencies.code
  title                 String // human-readable
  formNumber            String?   @map("form_number") // '3-177', '2877', nullable
  description           String // 1-3 sentences: what it is + when it applies
  jurisdiction          String    @default("US") // 'US' | 'EU' | 'UK' | 'INTL' — which import regime requires this
  type                  String    @default("N") // TARIC-style: 'C' cert | 'L' licence | 'U' origin | 'X' export | 'N' other | 'Y' negative declaration | 'PGA' US PGA flag
  triggeringHsChapters  Json      @default("[]") @map("triggering_hs_chapters") // [41, 42, 64] — HS2 chapters this typically touches; empty = any
  defaultSeverity       String    @map("default_severity") // 'required' | 'conditional' | 'alternative' | 'informational'
  url                   String? // link to the form or agency guidance
  status                String // 'flow_validating' | 'verified' | 'manual_override'
  source                String // 'llm' | 'cbp_pga' | 'manual'
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  verifiedAt            DateTime? @map("verified_at")

  agency RegulationAgency @relation(fields: [agencyCode], references: [code], onDelete: Restrict)

  @@index([agencyCode])
  @@map("certificate_catalog")
}

/// Per-lane LLM annotations on certificate_catalog rows. For a given
/// (HS6, origin, destination) the LLM is shown every triggered catalog
/// entry and asked "does this apply?" — the result is one row per
/// catalog entry, not per document. Replaces the freehand
/// freehand `required_documents` cache that was removed in PR 5. See
/// src/lib/catalog-annotations.ts. (Option C refactor — issue #15.)
model ClassificationCatalogAnnotation {
  id                 String    @id @default(uuid()) @db.Uuid
  hsCodePrefix       String    @map("hs_code_prefix") // 6-digit WCO subheading
  originCountry      String    @map("origin_country") // ISO2 or "ANY"
  destinationCountry String    @map("destination_country") // ISO2 or "EU"
  catalogCode        String    @map("catalog_code") // FK-by-value to certificate_catalog.code
  llmConfirmed       Boolean   @default(false) @map("llm_confirmed") // LLM thinks this applies for this lane
  rationale          String // 1-sentence why (or why not)
  confidence         Int? // 0-100
  severityOverride   String?   @map("severity_override") // override catalog.defaultSeverity for this lane
  note               String? // operator-added note surfaced to UI
  status             String // 'flow_validating' | 'verified' | 'manual_override'
  source             String // 'llm' | 'manual' | 'uk_trade_tariff' | 'taric' | 'ace'
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  verifiedAt         DateTime? @map("verified_at")

  @@unique([hsCodePrefix, originCountry, destinationCountry, catalogCode])
  @@index([hsCodePrefix, destinationCountry])
  @@index([catalogCode])
  @@map("classification_catalog_annotations")
}

/// CROSS ruling precedent matches per (HS6, query hash). v1 is a stub — the route
/// ships returning an empty rulings array behind a "closed beta" notice so clients
/// can integrate against the stable shape. Real fetcher slots into src/lib/precedents.ts.
model CrossRulingMatch {
  id           String    @id @default(uuid()) @db.Uuid
  hsCodePrefix String    @map("hs_code_prefix") // HS6 — broader match
  queryHash    String    @map("query_hash") // sha256 of normalized (hs10|title|materials)
  rulings      Json      @default("[]") // [{ ruling_number, date, hs_code, product, url, relevance }]
  source       String // 'cross_stub' | 'cross_scrape' | 'cross_api'
  status       String // 'flow_validating' | 'verified' | 'manual_override'
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  expiresAt    DateTime? @map("expires_at")

  @@unique([hsCodePrefix, queryHash])
  @@index([hsCodePrefix])
  @@map("cross_ruling_matches")
}

/// Idempotency-key store (VISION.md §4.2). When a write arrives with an
/// `Idempotency-Key` header, we INSERT a row here keyed on
/// (workspace_id, method, path, key). Duplicate keys with matching
/// request hash replay the stored response; mismatched hash returns 422;
/// in-flight duplicates return 409. Rows expire after 24h; 5xx responses
/// are not stored (retry should be allowed).
model IdempotencyKey {
  id              String    @id @default(uuid()) @db.Uuid
  workspaceId     String    @map("workspace_id") @db.Uuid
  method          String
  path            String
  key             String
  requestHash     String    @map("request_hash") // sha256 of raw body
  statusCode      Int?      @map("status_code")
  responseBody    Json?     @map("response_body")
  responseHeaders Json?     @map("response_headers")
  lockedAt        DateTime  @default(now()) @map("locked_at")
  completedAt    DateTime? @map("completed_at")
  expiresAt       DateTime  @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@unique([workspaceId, method, path, key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}
